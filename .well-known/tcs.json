{
  "schemaVersion": "tcs.repo/v1",
  "id": "takos-storage",
  "modulePath": ".",
  "kind": "storage",
  "surface": "service",
  "provider": "cloudflare",
  "category": "storage",
  "suggestedName": "storage",
  "name": {
    "ja": "Takos Storage",
    "en": "Takos Storage"
  },
  "description": {
    "ja": "HTTP API で使えるオブジェクトストレージサービスを公開します。",
    "en": "Deploys an object storage service with an HTTP API."
  },
  "badge": {
    "ja": "追加候補",
    "en": "Installable"
  },
  "iconUrl": "public/icons/takos-storage.svg",
  "inputs": [
    {
      "name": "project_name",
      "type": "string",
      "format": "text",
      "required": true,
      "defaultValue": "service-name-with-space",
      "label": {
        "ja": "サービス名",
        "en": "Service name"
      }
    },
    {
      "name": "worker_name",
      "type": "string",
      "format": "subdomain",
      "required": true,
      "defaultValue": "service-name-with-space",
      "label": {
        "ja": "公開サブドメイン",
        "en": "Public subdomain"
      }
    },
    {
      "name": "app_url",
      "type": "string",
      "format": "url",
      "required": true,
      "label": {
        "ja": "公開URL",
        "en": "Public URL"
      }
    },
    {
      "name": "storage_token_signing_key",
      "type": "string",
      "format": "token",
      "secret": true,
      "advanced": true,
      "label": {
        "ja": "Token signing key",
        "en": "Token signing key"
      }
    },
    {
      "name": "worker_bundle_url",
      "type": "string",
      "format": "url",
      "advanced": true,
      "defaultValue": "https://github.com/tako0614/takos-storage/releases/download/v0.1.1/worker.js",
      "label": {
        "ja": "Worker artifact URL",
        "en": "Worker artifact URL"
      }
    },
    {
      "name": "worker_bundle_sha256",
      "type": "string",
      "format": "sha256",
      "advanced": true,
      "defaultValue": "9f9e3a8584048ec49fce4aa2ca9f8b3b942a35c6339c4e4e39aee306a4587a1b",
      "label": {
        "ja": "Worker artifact SHA-256",
        "en": "Worker artifact SHA-256"
      }
    }
  ],
  "installExperience": {
    "projections": [
      {
        "kind": "service_name",
        "variable": "project_name"
      },
      {
        "kind": "public_endpoint",
        "variables": {
          "subdomain": "worker_name",
          "url": "app_url",
          "routePattern": "cloudflare_route_pattern"
        },
        "baseDomain": "app.takos.jp"
      },
      {
        "kind": "initial_secret",
        "variable": "storage_token_signing_key",
        "secretKind": "token",
        "optional": true
      },
      {
        "kind": "artifact",
        "variables": {
          "url": "worker_bundle_url",
          "sha256": "worker_bundle_sha256"
        }
      }
    ]
  },
  "outputAllowlist": [
    {
      "key": "launch_url",
      "from": "launch_url",
      "type": "url"
    },
    {
      "key": "url",
      "from": "url",
      "type": "url"
    },
    {
      "key": "storage_api_base_url",
      "from": "storage_api_base_url",
      "type": "url"
    },
    {
      "key": "app_deployment",
      "from": "app_deployment",
      "type": "json"
    },
    {
      "key": "service_exports",
      "from": "service_exports",
      "type": "json"
    }
  ]
}
